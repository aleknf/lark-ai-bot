# ===========================================
# Lark AI Bot Server — Environment Variables
# ===========================================

# Server
PORT=3000
NODE_ENV=development

# ===========================================
# OpenRouter (https://openrouter.ai/keys)
# ===========================================
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Model to use (see https://openrouter.ai/models)
# Recommended: openai/gpt-4o, anthropic/claude-3.5-sonnet, google/gemini-2.0-flash
OPENROUTER_MODEL=deepseek/deepseek-v3.2

# Optional: Your app name/URL for OpenRouter rankings
OPENROUTER_APP_NAME=LarkAIBot
OPENROUTER_APP_URL=http://localhost:3000

# ===========================================
# Lark Bot App (from Lark Developer Console)
# ===========================================
LARK_APP_ID=cli_xxxxxxxxxxxxxxxx
LARK_APP_SECRET=your-app-secret-here
LARK_VERIFICATION_TOKEN=your-verification-token-here

# ===========================================
# Lark CLI (installed separately)
# Run `lark-cli config init --new` once to configure
# ===========================================

# ===========================================
# Optional: Default Lark Resources
# ===========================================
# LARK_DEFAULT_BASE_TOKEN=BA...  # default Base for /search command
# LARK_DEFAULT_SHEET_TOKEN=st... # default Sheet for /sheet command

# ===========================================
# AI Pipeline
# ===========================================
# Maximum chat history messages to include as context
AI_MAX_CONTEXT_MESSAGES=20

# System prompt for the AI assistant
AI_SYSTEM_PROMPT="You are a helpful Lark bot assistant. You can help users search data in Lark Base, query Sheets, generate Docs reports, and answer questions. Be concise and helpful."
